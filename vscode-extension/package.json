{
	"name": "vortex-lang",
	"displayName": "Vortex Language Support",
	"description": "Syntax highlighting, intellisense, and YAML validation for .vortex config files",
	"version": "0.4.0",
	"publisher": "arcmantle",
	"icon": "icons/icon.png",
	"repository": {
		"type": "git",
		"url": "https://github.com/arcmantle/vortex"
	},
	"engines": {
		"vscode": "^1.85.0"
	},
	"categories": [
		"Programming Languages"
	],
	"activationEvents": [
		"workspaceContains:**/*.vortex"
	],
	"main": "./out/extension.js",
	"contributes": {
		"languages": [
			{
				"id": "vortex",
				"aliases": [
					"Vortex",
					"vortex"
				],
				"extensions": [
					".vortex"
				],
				"configuration": "./language-configuration.json",
				"icon": {
					"light": "./icons/vortex-light.svg",
					"dark": "./icons/vortex-dark.svg"
				}
			}
		],
		"grammars": [
			{
				"language": "vortex",
				"scopeName": "source.vortex",
				"path": "./syntaxes/vortex.tmLanguage.json"
			}
		],
		"commands": [
			{
				"command": "vortex.viewAssembledSource",
				"title": "View Assembled JS",
				"category": "Vortex",
				"icon": "$(code)"
			}
		],
		"menus": {
			"editor/title": [
				{
					"command": "vortex.viewAssembledSource",
					"when": "resourceExtname == .vortex",
					"group": "navigation"
				}
			]
		},
		"configurationDefaults": {
			"[vortex]": {
				"editor.insertSpaces": true,
				"editor.tabSize": 2,
				"editor.detectIndentation": false,
				"editor.autoIndent": "keep",
				"editor.formatOnSave": true
			}
		}
	},
	"scripts": {
		"build": "node build.js",
		"watch": "pnpm build --watch",
		"package": "vsce package --no-dependencies"
	},
	"devDependencies": {
		"@types/node": "^20.0.0",
		"@types/vscode": "^1.85.0",
		"esbuild": "^0.24.0",
		"typescript": "^5.5.0",
		"vitest": "^4.1.5",
		"vscode-languageclient": "^9.0.1",
		"vscode-languageserver-protocol": "^3.17.5",
		"yaml-language-server": "^1.22.0"
	},
	"dependencies": {
		"shiki": "^1.29.2",
		"yaml": "^2.7.0"
	}
}