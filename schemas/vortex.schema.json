{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"$id": "https://raw.githubusercontent.com/arcmantle/vortex/master/schemas/vortex.schema.json",
	"title": "Vortex Config",
	"description": "Configuration file for the Vortex process orchestrator.",
	"type": "object",
	"additionalProperties": false,
	"required": [
		"name",
		"jobs"
	],
	"properties": {
		"name": {
			"type": "string",
			"minLength": 1,
			"pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$",
			"description": "Instance name used to target this running Vortex configuration."
		},
		"node": {
			"$ref": "#/definitions/nodeRuntime"
		},
		"bun": {
			"$ref": "#/definitions/bunRuntime"
		},
		"deno": {
			"$ref": "#/definitions/denoRuntime"
		},
		"csharp": {
			"$ref": "#/definitions/csharpRuntime"
		},
		"go": {
			"$ref": "#/definitions/goRuntime"
		},
		"jobs": {
			"type": "array",
			"minItems": 1,
			"items": {
				"$ref": "#/definitions/job"
			}
		}
	},
	"defaultSnippets": [
		{
			"label": "Basic Vortex config",
			"body": {
				"name": "$1",
				"jobs": [
					{
						"id": "$2",
						"command": "$3"
					}
				]
			}
		},
		{
			"label": "Shell-backed job",
			"body": {
				"name": "$1",
				"jobs": [
					{
						"id": "$2",
						"shell": "node",
						"command": "console.log('hello from vortex')"
					}
				]
			}
		},
		{
			"label": "OS-specific command",
			"body": {
				"name": "$1",
				"jobs": [
					{
						"id": "$2",
						"shell": {
							"default": "bash",
							"windows": "pwsh"
						},
						"command": {
							"default": "echo hello from vortex",
							"windows": "Write-Host hello from vortex"
						}
					}
				]
			}
		},
		{
			"label": "Node shared runtime",
			"body": {
				"name": "$1",
				"node": {
					"imports": [
						{
							"from": "node:path",
							"names": [
								"basename"
							]
						}
					],
					"vars": {
						"apiBase": "http://localhost:3000"
					},
					"functions": {
						"logBanner": "export function logBanner(text) {\n  console.log(text)\n}"
					}
				},
				"jobs": [
					{
						"id": "$2",
						"shell": "node",
						"use": "node",
						"command": "logBanner(apiBase)\nconsole.log(basename('/tmp/demo.txt'))"
					}
				]
			}
		},
		{
			"label": "Bun shared runtime",
			"body": {
				"name": "$1",
				"bun": {
					"imports": [
						{
							"from": "node:path",
							"names": [
								"basename"
							]
						}
					],
					"vars": {
						"apiBase": "http://localhost:3000"
					},
					"functions": {
						"logBanner": "export function logBanner(text) {\n  console.log(text)\n}"
					}
				},
				"jobs": [
					{
						"id": "$2",
						"shell": "bun",
						"use": "bun",
						"command": "logBanner(apiBase)\nconsole.log(basename('/tmp/demo.txt'))"
					}
				]
			}
		},
		{
			"label": "Deno shared runtime",
			"body": {
				"name": "$1",
				"deno": {
					"imports": [
						{
							"from": "https://deno.land/std/path/mod.ts",
							"names": [
								"basename"
							]
						}
					],
					"vars": {
						"apiBase": "http://localhost:3000"
					},
					"functions": {
						"logBanner": "export function logBanner(text) {\n  console.log(text)\n}"
					}
				},
				"jobs": [
					{
						"id": "$2",
						"shell": "deno",
						"use": "deno",
						"command": "logBanner(apiBase)\nconsole.log(basename('/tmp/demo.txt'))"
					}
				]
			}
		},
		{
			"label": "C# shared runtime",
			"body": {
				"name": "$1",
				"csharp": {
					"usings": [
						"System.IO"
					],
					"packages": [
						{
							"name": "Newtonsoft.Json",
							"version": "13.0.3"
						}
					],
					"vars": {
						"apiBase": "http://localhost:3000"
					},
					"functions": {
						"LogBanner": "public static void LogBanner(string text)\n{\n    Console.WriteLine($\"== {text} ==\");\n}"
					}
				},
				"jobs": [
					{
						"id": "$2",
						"shell": "csharp",
						"use": "csharp",
						"command": "LogBanner(apiBase);\nConsole.WriteLine(Path.GetFileName(\"/tmp/demo.txt\"));"
					}
				]
			}
		},
		{
			"label": "Go shared runtime",
			"body": {
				"name": "$1",
				"go": {
					"imports": [
						{
							"path": "fmt",
							"version": "std"
						}
					],
					"vars": {
						"apiBase": "http://localhost:3000"
					},
					"functions": {
						"logBanner": "func logBanner(text string) {\n\tfmt.Printf(\"== %s ==\\n\", text)\n}"
					}
				},
				"jobs": [
					{
						"id": "$2",
						"shell": "go",
						"use": "go",
						"command": "logBanner(apiBase)\nfmt.Println(\"hello from vortex\")"
					}
				]
			}
		}
	],
	"definitions": {
		"jsIdentifier": {
			"type": "string",
			"pattern": "^[A-Za-z_$][A-Za-z0-9_$]*$"
		},
		"shellName": {
			"type": "string",
			"enum": [
				"bash",
				"sh",
				"zsh",
				"fish",
				"cmd",
				"powershell",
				"pwsh",
				"python",
				"python3",
				"node",
				"deno",
				"bun",
				"csharp",
				"go"
			]
		},
		"osSelectorKeys": {
			"enum": [
				"darwin",
				"linux",
				"windows",
				"default"
			]
		},
		"shellSelector": {
			"type": "object",
			"minProperties": 1,
			"propertyNames": {
				"$ref": "#/definitions/osSelectorKeys"
			},
			"additionalProperties": {
				"$ref": "#/definitions/shellName"
			}
		},
		"commandSelector": {
			"type": "object",
			"minProperties": 1,
			"propertyNames": {
				"$ref": "#/definitions/osSelectorKeys"
			},
			"additionalProperties": {
				"type": "string",
				"minLength": 1
			}
		},
		"nodeNamedImportAlias": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"export"
			],
			"properties": {
				"export": {
					"type": "string",
					"minLength": 1
				},
				"as": {
					"$ref": "#/definitions/jsIdentifier"
				}
			}
		},
		"nodeImportDefault": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"from",
				"default"
			],
			"properties": {
				"from": {
					"type": "string",
					"minLength": 1
				},
				"default": {
					"$ref": "#/definitions/jsIdentifier"
				}
			}
		},
		"nodeImportNamespace": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"from",
				"namespace"
			],
			"properties": {
				"from": {
					"type": "string",
					"minLength": 1
				},
				"namespace": {
					"$ref": "#/definitions/jsIdentifier"
				}
			}
		},
		"nodeImportNames": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"from",
				"names"
			],
			"properties": {
				"from": {
					"type": "string",
					"minLength": 1
				},
				"names": {
					"type": "array",
					"minItems": 1,
					"uniqueItems": true,
					"items": {
						"$ref": "#/definitions/jsIdentifier"
					}
				}
			}
		},
		"nodeImportNamed": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"from",
				"named"
			],
			"properties": {
				"from": {
					"type": "string",
					"minLength": 1
				},
				"named": {
					"type": "array",
					"minItems": 1,
					"items": {
						"$ref": "#/definitions/nodeNamedImportAlias"
					}
				}
			}
		},
		"nodeImport": {
			"oneOf": [
				{
					"$ref": "#/definitions/nodeImportDefault"
				},
				{
					"$ref": "#/definitions/nodeImportNamespace"
				},
				{
					"$ref": "#/definitions/nodeImportNames"
				},
				{
					"$ref": "#/definitions/nodeImportNamed"
				}
			]
		},
		"nodeRuntime": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"typescript": {
					"type": "boolean",
					"description": "Enable TypeScript mode. When true, generated wrappers use .mts and are bundled via esbuild before running with Node. Auto-detected when any source has a .ts/.mts/.cts extension."
				},
				"sources": {
					"type": "array",
					"items": {
						"type": "string",
						"minLength": 1
					},
					"description": "Local .mjs/.js/.ts/.mts files included as namespace imports. Each file's exports are available via a camelCase namespace derived from the filename (e.g. run-helper.mjs → runHelper)."
				},
				"imports": {
					"type": "array",
					"items": {
						"$ref": "#/definitions/nodeImport"
					}
				},
				"vars": {
					"type": "object",
					"propertyNames": {
						"$ref": "#/definitions/jsIdentifier"
					},
					"additionalProperties": true
				},
				"functions": {
					"type": "object",
					"propertyNames": {
						"$ref": "#/definitions/jsIdentifier"
					},
					"additionalProperties": {
						"type": "string",
						"minLength": 1
					}
				}
			}
		},
		"bunRuntime": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"typescript": {
					"type": "boolean",
					"description": "Enable TypeScript mode. When true, generated wrappers use .mts (Bun runs TypeScript natively). Auto-detected when any source has a .ts/.mts/.cts extension."
				},
				"sources": {
					"type": "array",
					"items": {
						"type": "string",
						"minLength": 1
					},
					"description": "Local .mjs/.js/.ts/.mts files included as namespace imports. Each file's exports are available via a camelCase namespace derived from the filename (e.g. run-helper.mjs → runHelper)."
				},
				"imports": {
					"type": "array",
					"items": {
						"$ref": "#/definitions/nodeImport"
					}
				},
				"vars": {
					"type": "object",
					"propertyNames": {
						"$ref": "#/definitions/jsIdentifier"
					},
					"additionalProperties": true
				},
				"functions": {
					"type": "object",
					"propertyNames": {
						"$ref": "#/definitions/jsIdentifier"
					},
					"additionalProperties": {
						"type": "string",
						"minLength": 1
					}
				}
			}
		},
		"denoRuntime": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"typescript": {
					"type": "boolean",
					"description": "Enable TypeScript mode. When true, generated wrappers use .mts (Deno runs TypeScript natively). Auto-detected when any source has a .ts/.mts/.cts extension."
				},
				"sources": {
					"type": "array",
					"items": {
						"type": "string",
						"minLength": 1
					},
					"description": "Local .mjs/.js/.ts/.mts files included as namespace imports. Each file's exports are available via a camelCase namespace derived from the filename."
				},
				"imports": {
					"type": "array",
					"items": {
						"$ref": "#/definitions/nodeImport"
					}
				},
				"vars": {
					"type": "object",
					"propertyNames": {
						"$ref": "#/definitions/jsIdentifier"
					},
					"additionalProperties": true
				},
				"functions": {
					"type": "object",
					"propertyNames": {
						"$ref": "#/definitions/jsIdentifier"
					},
					"additionalProperties": {
						"type": "string",
						"minLength": 1
					}
				}
			}
		},
		"csharpIdentifier": {
			"type": "string",
			"pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
		},
		"csharpPackage": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"name",
				"version"
			],
			"properties": {
				"name": {
					"type": "string",
					"minLength": 1,
					"description": "NuGet package name."
				},
				"version": {
					"type": "string",
					"minLength": 1,
					"description": "NuGet package version."
				}
			}
		},
		"csharpRuntime": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"framework": {
					"type": "string",
					"minLength": 1,
					"description": "Target framework moniker (e.g. net8.0, net9.0). Defaults to net8.0."
				},
				"sources": {
					"type": "array",
					"items": {
						"type": "string",
						"minLength": 1
					},
					"description": "Local .cs files copied into the generated project. Classes and methods defined in these files are available in job commands."
				},
				"usings": {
					"type": "array",
					"items": {
						"type": "string",
						"minLength": 1
					},
					"description": "Additional using directives injected into the shared source."
				},
				"packages": {
					"type": "array",
					"items": {
						"$ref": "#/definitions/csharpPackage"
					},
					"description": "NuGet package references added to the generated project."
				},
				"vars": {
					"type": "object",
					"propertyNames": {
						"$ref": "#/definitions/csharpIdentifier"
					},
					"additionalProperties": true,
					"description": "Variables exposed as public static readonly fields on the Vortex class."
				},
				"functions": {
					"type": "object",
					"propertyNames": {
						"$ref": "#/definitions/csharpIdentifier"
					},
					"additionalProperties": {
						"type": "string",
						"minLength": 1
					},
					"description": "Static methods added to the Vortex class, accessible via using static."
				}
			}
		},
		"goIdentifier": {
			"type": "string",
			"pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
		},
		"goModule": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"path",
				"version"
			],
			"properties": {
				"path": {
					"type": "string",
					"minLength": 1,
					"description": "Go module path (e.g. github.com/fatih/color)."
				},
				"version": {
					"type": "string",
					"minLength": 1,
					"description": "Module version (e.g. v1.16.0)."
				}
			}
		},
		"goRuntime": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"module": {
					"type": "string",
					"minLength": 1,
					"description": "Go module name for the generated project. Defaults to vortex/runtime."
				},
				"sources": {
					"type": "array",
					"items": {
						"type": "string",
						"minLength": 1
					},
					"description": "Local .go files copied into the generated project. Functions and types defined in these files are available in job commands."
				},
				"imports": {
					"type": "array",
					"items": {
						"$ref": "#/definitions/goModule"
					},
					"description": "Go module dependencies added to go.mod."
				},
				"vars": {
					"type": "object",
					"propertyNames": {
						"$ref": "#/definitions/goIdentifier"
					},
					"additionalProperties": true,
					"description": "Variables exposed as package-level var declarations."
				},
				"functions": {
					"type": "object",
					"propertyNames": {
						"$ref": "#/definitions/goIdentifier"
					},
					"additionalProperties": {
						"type": "string",
						"minLength": 1
					},
					"description": "Top-level function declarations available in all job commands."
				}
			}
		},
		"job": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"id",
				"command"
			],
			"properties": {
				"id": {
					"type": "string",
					"minLength": 1,
					"pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$",
					"description": "Unique job identifier used in needs references."
				},
				"label": {
					"type": "string",
					"minLength": 1,
					"description": "Human-readable job label shown in the UI."
				},
				"use": {
					"type": "string",
					"enum": [
						"node",
						"bun",
						"deno",
						"csharp",
						"go"
					],
					"description": "Opt the job into the top-level shared runtime. Supports `node` (requires `shell: node`), `bun` (requires `shell: bun`), `deno` (requires `shell: deno`), `csharp` (requires `shell: csharp`), and `go` (requires `shell: go`)."
				},
				"shell": {
					"oneOf": [
						{
							"$ref": "#/definitions/shellName"
						},
						{
							"$ref": "#/definitions/shellSelector"
						}
					],
					"description": "Optional interpreter used for command script blocks."
				},
				"command": {
					"oneOf": [
						{
							"type": "string",
							"minLength": 1
						},
						{
							"$ref": "#/definitions/commandSelector"
						}
					],
					"description": "Command line when shell is omitted, or script text when shell is set."
				},
				"group": {
					"type": "string",
					"minLength": 1,
					"description": "Optional group name used to visually group jobs in the UI."
				},
				"needs": {
					"type": "array",
					"items": {
						"type": "string",
						"minLength": 1
					},
					"uniqueItems": true,
					"default": []
				},
				"if": {
					"type": "string",
					"enum": [
						"success",
						"failure",
						"always"
					],
					"description": "Dependency condition that controls when the job runs."
				},
				"restart": {
					"type": "boolean",
					"description": "Whether the job should be restarted when the config is reloaded."
				}
			}
		}
	},
	"examples": [
		{
			"name": "dev",
			"node": {
				"imports": [
					{
						"from": "node:path",
						"names": [
							"basename"
						]
					}
				],
				"vars": {
					"apiBase": "http://localhost:3000"
				},
				"functions": {
					"logBanner": "export function logBanner(text) { console.log(text) }"
				}
			},
			"jobs": [
				{
					"id": "build",
					"command": "go build ./...",
					"group": "ci"
				},
				{
					"id": "smoke-node",
					"shell": "node",
					"use": "node",
					"command": "console.log('vortex schema ready')",
					"needs": [
						"build"
					]
				},
				{
					"id": "cross-platform",
					"shell": {
						"default": "bash",
						"windows": "pwsh"
					},
					"command": {
						"default": "echo hello",
						"windows": "Write-Host hello"
					}
				}
			]
		}
	]
}