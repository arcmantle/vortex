{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"types": ["vite/client"],
		"allowJs": false,
		"checkJs": false,
		"noEmit": true,
		"strict": true,
		"skipLibCheck": true,
		"useDefineForClassFields": false,
		"experimentalDecorators": true,
		"emitDecoratorMetadata": false
	},
	"include": ["app.ts"]
}