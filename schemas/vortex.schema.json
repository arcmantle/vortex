{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"$id": "https://raw.githubusercontent.com/arcmantle/vortex/master/schemas/vortex.schema.json",
	"title": "Vortex Config",
	"description": "Configuration file for the Vortex process orchestrator.",
	"type": "object",
	"additionalProperties": false,
	"required": [
		"name",
		"jobs"
	],
	"properties": {
		"name": {
			"type": "string",
			"minLength": 1,
			"pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$",
			"description": "Instance name used to target this running Vortex configuration."
		},
		"node": {
			"$ref": "#/definitions/nodeRuntime"
		},
		"jobs": {
			"type": "array",
			"minItems": 1,
			"items": {
				"$ref": "#/definitions/job"
			}
		}
	},
	"defaultSnippets": [
		{
			"label": "Basic Vortex config",
			"body": {
				"name": "$1",
				"jobs": [
					{
						"id": "$2",
						"command": "$3"
					}
				]
			}
		},
		{
			"label": "Shell-backed job",
			"body": {
				"name": "$1",
				"jobs": [
					{
						"id": "$2",
						"shell": "node",
						"command": "console.log('hello from vortex')"
					}
				]
			}
		},
		{
			"label": "OS-specific command",
			"body": {
				"name": "$1",
				"jobs": [
					{
						"id": "$2",
						"shell": {
							"default": "bash",
							"windows": "pwsh"
						},
						"command": {
							"default": "echo hello from vortex",
							"windows": "Write-Host hello from vortex"
						}
					}
				]
			}
		},
		{
			"label": "Node shared runtime",
			"body": {
				"name": "$1",
				"node": {
					"imports": [
						{
							"from": "node:path",
							"names": [
								"basename"
							]
						}
					],
					"vars": {
						"apiBase": "http://localhost:3000"
					},
					"functions": {
						"logBanner": "export function logBanner(text) {\n  console.log(text)\n}"
					}
				},
				"jobs": [
					{
						"id": "$2",
						"shell": "node",
						"use": "node",
						"command": "logBanner(apiBase)\nconsole.log(basename('/tmp/demo.txt'))"
					}
				]
			}
		}
	],
	"definitions": {
		"jsIdentifier": {
			"type": "string",
			"pattern": "^[A-Za-z_$][A-Za-z0-9_$]*$"
		},
		"shellName": {
			"type": "string",
			"enum": [
				"bash",
				"sh",
				"zsh",
				"fish",
				"cmd",
				"powershell",
				"pwsh",
				"python",
				"python3",
				"node",
				"deno",
				"bun"
			]
		},
		"osSelectorKeys": {
			"enum": [
				"darwin",
				"linux",
				"windows",
				"default"
			]
		},
		"shellSelector": {
			"type": "object",
			"minProperties": 1,
			"propertyNames": {
				"$ref": "#/definitions/osSelectorKeys"
			},
			"additionalProperties": {
				"$ref": "#/definitions/shellName"
			}
		},
		"commandSelector": {
			"type": "object",
			"minProperties": 1,
			"propertyNames": {
				"$ref": "#/definitions/osSelectorKeys"
			},
			"additionalProperties": {
				"type": "string",
				"minLength": 1
			}
		},
		"nodeNamedImportAlias": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"export"
			],
			"properties": {
				"export": {
					"type": "string",
					"minLength": 1
				},
				"as": {
					"$ref": "#/definitions/jsIdentifier"
				}
			}
		},
		"nodeImportDefault": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"from",
				"default"
			],
			"properties": {
				"from": {
					"type": "string",
					"minLength": 1
				},
				"default": {
					"$ref": "#/definitions/jsIdentifier"
				}
			}
		},
		"nodeImportNamespace": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"from",
				"namespace"
			],
			"properties": {
				"from": {
					"type": "string",
					"minLength": 1
				},
				"namespace": {
					"$ref": "#/definitions/jsIdentifier"
				}
			}
		},
		"nodeImportNames": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"from",
				"names"
			],
			"properties": {
				"from": {
					"type": "string",
					"minLength": 1
				},
				"names": {
					"type": "array",
					"minItems": 1,
					"uniqueItems": true,
					"items": {
						"$ref": "#/definitions/jsIdentifier"
					}
				}
			}
		},
		"nodeImportNamed": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"from",
				"named"
			],
			"properties": {
				"from": {
					"type": "string",
					"minLength": 1
				},
				"named": {
					"type": "array",
					"minItems": 1,
					"items": {
						"$ref": "#/definitions/nodeNamedImportAlias"
					}
				}
			}
		},
		"nodeImport": {
			"oneOf": [
				{
					"$ref": "#/definitions/nodeImportDefault"
				},
				{
					"$ref": "#/definitions/nodeImportNamespace"
				},
				{
					"$ref": "#/definitions/nodeImportNames"
				},
				{
					"$ref": "#/definitions/nodeImportNamed"
				}
			]
		},
		"nodeRuntime": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"imports": {
					"type": "array",
					"items": {
						"$ref": "#/definitions/nodeImport"
					}
				},
				"vars": {
					"type": "object",
					"propertyNames": {
						"$ref": "#/definitions/jsIdentifier"
					},
					"additionalProperties": true
				},
				"functions": {
					"type": "object",
					"propertyNames": {
						"$ref": "#/definitions/jsIdentifier"
					},
					"additionalProperties": {
						"type": "string",
						"minLength": 1
					}
				}
			}
		},
		"job": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"id",
				"command"
			],
			"properties": {
				"id": {
					"type": "string",
					"minLength": 1,
					"pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$",
					"description": "Unique job identifier used in needs references."
				},
				"label": {
					"type": "string",
					"minLength": 1,
					"description": "Human-readable job label shown in the UI."
				},
				"use": {
					"type": "string",
					"enum": [
						"node"
					],
					"description": "Opt the job into the top-level shared runtime. V1 supports only `node` and requires `shell: node`."
				},
				"shell": {
					"oneOf": [
						{
							"$ref": "#/definitions/shellName"
						},
						{
							"$ref": "#/definitions/shellSelector"
						}
					],
					"description": "Optional interpreter used for command script blocks."
				},
				"command": {
					"oneOf": [
						{
							"type": "string",
							"minLength": 1
						},
						{
							"$ref": "#/definitions/commandSelector"
						}
					],
					"description": "Command line when shell is omitted, or script text when shell is set."
				},
				"group": {
					"type": "string",
					"minLength": 1,
					"description": "Optional group name used to visually group jobs in the UI."
				},
				"needs": {
					"type": "array",
					"items": {
						"type": "string",
						"minLength": 1
					},
					"uniqueItems": true,
					"default": []
				},
				"if": {
					"type": "string",
					"enum": [
						"success",
						"failure",
						"always"
					],
					"description": "Dependency condition that controls when the job runs."
				},
				"restart": {
					"type": "boolean",
					"description": "Whether the job should be restarted when the config is reloaded."
				}
			}
		}
	},
	"examples": [
		{
			"name": "dev",
			"node": {
				"imports": [
					{
						"from": "node:path",
						"names": [
							"basename"
						]
					}
				],
				"vars": {
					"apiBase": "http://localhost:3000"
				},
				"functions": {
					"logBanner": "export function logBanner(text) { console.log(text) }"
				}
			},
			"jobs": [
				{
					"id": "build",
					"command": "go build ./...",
					"group": "ci"
				},
				{
					"id": "smoke-node",
					"shell": "node",
					"use": "node",
					"command": "console.log('vortex schema ready')",
					"needs": [
						"build"
					]
				},
				{
					"id": "cross-platform",
					"shell": {
						"default": "bash",
						"windows": "pwsh"
					},
					"command": {
						"default": "echo hello",
						"windows": "Write-Host hello"
					}
				}
			]
		}
	]
}