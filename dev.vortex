jobs:
  # ── network group ─────────────────────────────────────────────────────────
  - id: ping-local
    label: localhost
    command: ping -t localhost
    group: network

  - id: ping-google
    label: Google DNS
    command: ping -t 8.8.8.8
    group: network

  - id: ping-cloudflare
    label: Cloudflare DNS
    command: ping -t 1.1.1.1
    group: network

  # ── build group ───────────────────────────────────────────────────────────
  - id: build
    label: Build
    command: go build ./...
    group: build

  - id: test
    label: Test
    command: go test ./...
    group: build
    needs: [build]

  - id: test-fail
    label: Test (on failure)
    command: echo "build failed, running diagnostics"
    group: build
    needs: [build]
    if: failure